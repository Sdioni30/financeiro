# Copie este arquivo para .env e preencha os valores antes de rodar a aplicação.
# O arquivo .env nunca deve ser commitado no git.

# Banco de dados
DB_URL=jdbc:mysql://localhost:3306/db_financeiro
DB_USER=root
DB_PASSWORD=sua_senha_aqui

# JWT — gere uma chave aleatória segura (mínimo 32 caracteres)
# Exemplo de geração no terminal:
#   Linux/Mac: openssl rand -hex 32
#   PowerShell: -join ((1..32) | ForEach-Object { '{0:X2}' -f (Get-Random -Max 256) })
JWT_SECRET=substitua_por_uma_chave_longa_e_aleatoria_aqui
JWT_EXPIRATION=7200000